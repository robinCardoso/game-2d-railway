{
  "name": "tibia-web-engine",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "main": "desktop/electron/dist/main.js",
  "scripts": {
    "dev": "node scripts/free-dev-ports.mjs && concurrently -k -n api,web -c green,blue \"npm run dev --prefix server\" \"node scripts/wait-api-then-vite.mjs\"",
    "dev:web": "vite",
    "dev:server": "npm run dev --prefix server",
    "server": "npm run start --prefix server",
    "build:assets": "node scripts/write-pack-public-key.mjs && node scripts/pack-assets.mjs",
    "build": "npm run build:assets && tsc && vite build && npm run build --prefix server",
    "start": "npm run start --prefix server",
    "start:railway": "npm run build && npm run start",
    "pack": "npm run build:assets",
    "smoke:asset-pack": "node scripts/smoke-asset-pack.mjs",
    "preview": "vite preview",
    "test": "vitest run && node scripts/check-calibrator-listeners.mjs && node scripts/check-pack-artifacts-tracked.mjs",
    "migrate:character-calibration": "node scripts/migrate-character-calibration.mjs",
    "generate:spell-cast-sprites": "node scripts/generate-spell-cast-sprites.mjs",
    "generate:item-icons": "node scripts/generate-item-icon-sprites.mjs",
    "generate:spell-icons": "node scripts/generate-spell-icon-sprites.mjs --update-catalog",
    "test:calibrator": "node scripts/check-calibrator-listeners.mjs",
    "electron:compile": "tsc -p desktop/electron/tsconfig.json && node scripts/write-electron-dist-package.mjs",
    "electron:check": "npm run build && npm run electron:compile",
    "electron:dev": "node scripts/free-dev-ports.mjs && npm run electron:compile && concurrently -k -n api,web,electron -c green,blue,cyan \"npm run dev --prefix server\" \"node scripts/wait-api-then-vite.mjs\" \"wait-on http://localhost:5173/index.html && cross-env NODE_ENV=development electron .\"",
    "electron:build": "node scripts/prepare-electron-release.mjs && npm run build && npm run electron:compile && node scripts/run-electron-builder.mjs",
    "mobile:init": "node scripts/mobile-init.mjs",
    "mobile:build": "tsc && vite build && npx cap sync android",
    "mobile:open:android": "npx cap open android",
    "mobile:run:android": "npx cap run android"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "pngjs": "^7.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.robincardoso.game2drailway",
    "productName": "Elarion Online",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/electron/dist/**/*",
      "package.json",
      "!desktop/electron/dist/**/*.ts",
      "!private_key.pem",
      "!public_key.pem"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/brand/icon-elarion.png",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Elarion Online"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "robinCardoso",
        "repo": "game-2d-railway",
        "releaseType": "release"
      }
    ]
  }
}
