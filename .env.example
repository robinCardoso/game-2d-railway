# Copie para `.env` no dev local:  copy .env.example .env
# Produção (Railway): configure em Variables no painel — NÃO commite secrets.
# Guia completo: docs/hosting.md

# ── Auth API (JWT + PostgreSQL) ───────────────────────────────────
# Local: Postgres na máquina ou Docker
DATABASE_URL=postgresql://user:pass@localhost:5432/game2d
# Railway Postgres: use Variable Reference (NÃO cole URL manual; NÃO use ${{DATABASE_URL}}):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Railway costuma exigir SSL:
# DATABASE_SSL=true

JWT_SECRET=change-me-in-production-use-long-random-string
BCRYPT_ROUNDS=10

# ── Frontend (build Vite — variáveis VITE_* entram no bundle) ─────
# Dev com Vite (:5173): mock localStorage por padrão
# VITE_USE_API_AUTH=true
# VITE_AUTH_MOCK=true
# VITE_AUTH_MOCK=false

# ── Servidor unificado ────────────────────────────────────────────
# PORT — Railway injeta automaticamente; local usa 8787
# HOST=0.0.0.0
# NODE_ENV=production

# Volume Railway (mapas/sprites do Studio — obrigatório em prod)
# DATA_ROOT=/data

# URL pública do app (CORS / cookies) — igual ao domínio gerado em Networking
# CLIENT_ORIGIN=https://game-2d-railway-production.up.railway.app

# Dev only: APIs Studio sem JWT (NUNCA em produção)
# STUDIO_MOCK_GM=true

# ── Ticket WebSocket (somente servidor) ───────────────────────────
ENTER_TICKET_SECRET=change-me-in-production
# WS_TICKET_TTL_MS=300000
# WS_POSITION_SAVE_INTERVAL_MS=20000
# REQUIRE_WS_TICKET=true   # auto true em prod quando DATABASE_URL existe

# Dev: ticket local sem POST /api/ws-ticket
# VITE_ENTER_TICKET_SECRET=change-me-in-production
# VITE_USE_SERVER_WS_TICKET=true

# ── Game WebSocket ──────────────────────────────────────────────────
# Local (Vite proxy → Express :8787):
VITE_GAME_SERVER_WS=ws://localhost:8787
# Produção Railway: NÃO definir (same-origin wss://<seu-dominio>)
# ou, se quiser fixar explicitamente:
# VITE_GAME_SERVER_WS=wss://game-2d-railway-production.up.railway.app
# Desligar multiplayer:
# VITE_GAME_SERVER_WS=false

# Studio GM em produção
# VITE_STUDIO_GUARD=true

# Analytics
# VITE_ANALYTICS=true
