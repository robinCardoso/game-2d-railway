# ── Auth API (Fase B — JWT + PostgreSQL) ─────────────────────────
# Servidor
DATABASE_URL=postgresql://user:pass@localhost:5432/game2d
# DATABASE_SSL=true
JWT_SECRET=change-me-in-production-use-long-random-string
BCRYPT_ROUNDS=10

# Frontend (build Vite)
# Produção: API auth ativa por padrão
# Dev com Vite: mock localStorage (padrão)
# VITE_USE_API_AUTH=true
# VITE_AUTH_MOCK=true
# VITE_AUTH_MOCK=false

# ── Servidor unificado (Fase A) ───────────────────────────────────
# PORT — injetado pelo Railway; fallback local 8787
# HOST=0.0.0.0
# NODE_ENV=production
# DATA_ROOT=/data
# CLIENT_ORIGIN=https://seu-app.up.railway.app
# STUDIO_MOCK_GM=true

# Ticket WS (Fase C — só no servidor; não expor VITE_* em produção)
ENTER_TICKET_SECRET=change-me-in-production
# WS_TICKET_TTL_MS=300000
# WS_POSITION_SAVE_INTERVAL_MS=20000
# REQUIRE_WS_TICKET=true
# Dev fallback local (quando VITE_USE_SERVER_WS_TICKET=false):
# VITE_ENTER_TICKET_SECRET=change-me-in-production
# VITE_USE_SERVER_WS_TICKET=true

# Game WebSocket
VITE_GAME_SERVER_WS=ws://localhost:8787
# VITE_GAME_SERVER_WS=false

# Studio: exigir login GM em produção
# VITE_STUDIO_GUARD=true

# Analytics
# VITE_ANALYTICS=true
