{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../shared/**/*.ts",
    "../src/game/experience.ts",
    "../src/game-data/mobPresetTypes.ts",
    "../src/game-data/itemCatalogTypes.ts",
    "../src/engine/character/calculateStats.ts",
    "../src/engine/combat/calculateDamage.ts"
  ],
  "exclude": [
    "../shared/**/*.test.ts",
    "../src/**/*.test.ts"
  ]
}
